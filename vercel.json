{
  "installCommand": "npm install axios",
  "outputDirectory": ".",
  "routes": [
    {
      "src": "/playlist/detail",
      "dest": "/api/playlist.js"
    },
    {
      "src": "/song/url",
      "dest": "/api/song.js"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs20.x"
    }
  }
}
